import { useState, useEffect } from 'react'
import { useNavigate, useSearchParams, Link } from 'react-router-dom'
import { apiFetch } from '../hooks/useApi'
import RivieraScene from '../components/RivieraScene'
import Icon, { BrandMark } from '../components/Icon'
import { soloDigitos, emailTieneArroba, reglasPassword, passwordValida } from '../utils/validacion'

/* Vías de registro · rol_id del backend: 4=Cliente/Turista · 3=Proveedor · 2=Ponente
   El asistente (rol 4) se divide en dos cuentas:
   · Cliente → viene de una empresa (se valida con un código de convenio)
   · Turista → viene por su cuenta (sin empresa) */
const TIPOS = [
  { rol: 4, tipo: 'cliente', icon: 'briefcase', label: 'Cliente',   hint: 'Vengo de una empresa' },
  { rol: 4, tipo: 'turista', icon: 'ticket',    label: 'Turista',   hint: 'Vengo por mi cuenta' },
  { rol: 3, tipo: null,      icon: 'store',     label: 'Proveedor', hint: 'Exhibo servicios' },
  { rol: 2, tipo: null,      icon: 'mic',       label: 'Ponente',   hint: 'Comparto ponencias' },
]

function tipoInicial(params) {
  const rol = parseInt(params.get('rol'))
  const tc = params.get('tipo')
  let idx = TIPOS.findIndex(t => t.rol === rol && (t.tipo === tc || t.tipo === null))
  if (idx < 0) idx = TIPOS.findIndex(t => t.rol === rol)
  return idx < 0 ? 0 : idx
}

export default function Register() {
  const navigate = useNavigate()
  const [params] = useSearchParams()
  const [sel, setSel] = useState(tipoInicial(params))
  const tipoActual = TIPOS[sel]

  const [form, setForm] = useState({ nombre: '', apellidos: '', email: '', password: '', telefono: '', empresa: '', codigo_empresa: '' })
  const [empresas, setEmpresas] = useState([])
  const [error, setError] = useState('')
  const [success, setSuccess] = useState(false)
  const [loading, setLoading] = useState(false)

  // Empresas con convenio (referencia para el cliente)
  useEffect(() => {
    apiFetch('/empresas/convenio').then(d => setEmpresas(Array.isArray(d) ? d : [])).catch(() => setEmpresas([]))
  }, [])

  const esCliente = tipoActual.rol === 4 && tipoActual.tipo === 'cliente'

  // Estado de las validaciones (para mostrar warnings en vivo)
  const reglas = reglasPassword(form.password)
  const passOk = passwordValida(form.password)
  const emailOk = form.email === '' || emailTieneArroba(form.email)

  const submit = async e => {
    e.preventDefault(); setError('')

    if (!emailTieneArroba(form.email)) { setError('El correo debe contener al menos una «@»'); return }
    if (!passOk) { setError('La contraseña no cumple los requisitos de seguridad'); return }
    if (esCliente && (!form.empresa || !form.codigo_empresa)) {
      setError('Como cliente debes indicar tu empresa y el código de validación que te dio'); return
    }

    const payload = {
      nombre: form.nombre, apellidos: form.apellidos, email: form.email,
      password: form.password, telefono: form.telefono, rol_id: tipoActual.rol,
      tipo_cuenta: tipoActual.tipo || 'cliente',
    }
    if (esCliente) { payload.empresa = form.empresa; payload.codigo_empresa = form.codigo_empresa }

    setLoading(true)
    try {
      await apiFetch('/auth/register', { method: 'POST', body: JSON.stringify(payload) })
      setSuccess(true)
      setTimeout(() => navigate('/login'), 2000)
    } catch (err) { setError(err.message) }
    finally { setLoading(false) }
  }

  return (
    <div className="auth-layout">
      <div className="auth-panel-left">
        <RivieraScene />
        <div className="auth-left-content">
          <span className="auth-brand-icon"><BrandMark size={44} /></span>
          <span className="auth-brand-eyebrow">Riviera Maya · Congresos 2026</span>
          <h1 className="auth-brand-title">Forma parte<br /><span>del evento</span></h1>
          <p className="auth-brand-desc">Crea tu cuenta como cliente, turista, proveedor o ponente y vive el evento donde las culturas se reúnen para hacer negocios.</p>
        </div>
      </div>

      <div className="auth-panel-right">
        <div className="auth-form-wrap">
          <Link to="/" className="auth-back"><Icon name="arrowLeft" size={16} /> Volver al inicio</Link>
          <h2 className="auth-form-title">Crear cuenta</h2>
          <p className="auth-form-sub">Selecciona tu tipo de registro y completa tus datos</p>

          {error && <div className="alert alert-error">{error}</div>}
          {success && <div className="alert alert-success"><Icon name="check" size={18} /> Registro exitoso, redirigiendo…</div>}

          <form onSubmit={submit}>
            {/* Selector de las vías de registro */}
            <div className="field">
              <label>Tipo de registro</label>
              <div className="seg seg-4">
                {TIPOS.map((t, i) => (
                  <button
                    type="button"
                    key={t.label}
                    className={`seg-opt ${sel === i ? 'on' : ''}`}
                    onClick={() => setSel(i)}
                  >
                    <Icon name={t.icon} size={22} />
                    <b style={{ fontFamily: 'var(--display)', fontSize: '.82rem', marginTop: '.35rem', color: 'var(--text)' }}>{t.label}</b>
                    <small>{t.hint}</small>
                  </button>
                ))}
              </div>
            </div>

            <div className="field-row">
              <div className="field"><label>Nombre</label><input type="text" value={form.nombre} onChange={e => setForm({ ...form, nombre: e.target.value })} required /></div>
              <div className="field"><label>Apellidos</label><input type="text" value={form.apellidos} onChange={e => setForm({ ...form, apellidos: e.target.value })} required /></div>
            </div>
            <div className="field">
              <label>Correo electrónico</label>
              <input
                type="email"
                value={form.email}
                onChange={e => setForm({ ...form, email: e.target.value })}
                className={!emailOk ? 'input-warn' : ''}
                required
              />
              {!emailOk && <p className="field-warn"><Icon name="alert" size={13} /> El correo debe contener al menos una «@»</p>}
            </div>

            {/* Datos de empresa: SOLO para el cliente. El turista no los ve. */}
            {esCliente && (
              <>
                <div className="info-note">
                  <Icon name="info" size={18} />
                  <div>Tu empresa debe tener <b>convenio</b> con el complejo. Captura el <b>código de validación</b> que ella te entregó: así corroboramos que vienes de parte de una empresa y estrenas una <b>habitación estándar</b> incluida.</div>
                </div>
                <div className="field">
                  <label>Empresa</label>
                  <input
                    type="text" list="empresas-convenio"
                    value={form.empresa}
                    onChange={e => setForm({ ...form, empresa: e.target.value })}
                    placeholder="Empresa con convenio"
                    required
                  />
                  <datalist id="empresas-convenio">
                    {empresas.map(em => <option key={em.id} value={em.nombre} />)}
                  </datalist>
                </div>
                <div className="field">
                  <label>Código de validación de empresa</label>
                  <input
                    type="text"
                    value={form.codigo_empresa}
                    onChange={e => setForm({ ...form, codigo_empresa: e.target.value })}
                    placeholder="Ej. EMPRESA-2026"
                    required
                  />
                </div>
              </>
            )}

            <div className="field">
              <label>Contraseña</label>
              <input
                type="password"
                value={form.password}
                onChange={e => setForm({ ...form, password: e.target.value })}
                className={form.password && !passOk ? 'input-warn' : ''}
                required
              />
              {/* Checklist de requisitos de la contraseña */}
              <ul className="pass-rules">
                <li className={reglas.longitud ? 'ok' : ''}><Icon name={reglas.longitud ? 'check' : 'x'} size={13} /> Mínimo 8 caracteres</li>
                <li className={reglas.mayuscula ? 'ok' : ''}><Icon name={reglas.mayuscula ? 'check' : 'x'} size={13} /> Una mayúscula (A-Z)</li>
                <li className={reglas.numero ? 'ok' : ''}><Icon name={reglas.numero ? 'check' : 'x'} size={13} /> Un número (0-9)</li>
                <li className={reglas.simbolo ? 'ok' : ''}><Icon name={reglas.simbolo ? 'check' : 'x'} size={13} /> Un símbolo (!@#$…)</li>
              </ul>
            </div>

            <div className="field">
              <label>Teléfono</label>
              <input
                type="tel"
                inputMode="numeric"
                value={form.telefono}
                onChange={e => setForm({ ...form, telefono: soloDigitos(e.target.value) })}
                placeholder="Solo números"
              />
            </div>

            <button type="submit" className="btn btn-primary btn-full" style={{ marginTop: '.5rem' }} disabled={loading}>
              {loading ? 'Creando cuenta…' : `Crear cuenta · ${tipoActual.label}`}
            </button>
          </form>
          <p className="auth-link">¿Ya tienes cuenta? <a href="/login">Inicia sesión</a></p>
        </div>
      </div>
    </div>
  )
}
